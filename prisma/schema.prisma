generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String            @id @default(uuid())
  email                    String            @unique
  username                 String            @unique
  passwordHash             String
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  character                Character?
  friendRequestsSent       FriendRequest[]   @relation("FriendRequestsSent")
  friendRequestsReceived   FriendRequest[]   @relation("FriendRequestsReceived")
  mutesMade                Mute[]            @relation("MutesMade")
  mutesReceived            Mute[]            @relation("MutesReceived")
  chatMessages             ChatMessage[]
  guildMembership          GuildMember?
  guildInvitesSent         GuildInvite[]     @relation("GuildInvitesSent")
  guildInvitesReceived     GuildInvite[]     @relation("GuildInvitesReceived")
  privateMessagesSent      PrivateMessage[]  @relation("PrivateMessagesSent")
  privateMessagesReceived  PrivateMessage[]  @relation("PrivateMessagesReceived")
  tradeOffersSent          TradeOffer[]      @relation("TradeOffersSent")
  tradeOffersReceived      TradeOffer[]      @relation("TradeOffersReceived")
  auditLogEntries          AuditLogEntry[]

  @@map("users")
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model FriendRequest {
  id          String              @id @default(uuid())
  requesterId String
  requester   User                @relation("FriendRequestsSent", fields: [requesterId], references: [id])
  addresseeId String
  addressee   User                @relation("FriendRequestsReceived", fields: [addresseeId], references: [id])
  status      FriendRequestStatus @default(PENDING)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@map("friend_requests")
}

model Mute {
  id        String   @id @default(uuid())
  muterId   String
  muter     User     @relation("MutesMade", fields: [muterId], references: [id])
  mutedId   String
  muted     User     @relation("MutesReceived", fields: [mutedId], references: [id])
  createdAt DateTime @default(now())

  @@unique([muterId, mutedId])
  @@map("mutes")
}

model ChatMessage {
  id        String   @id @default(uuid())
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  channel   String   @default("global")
  body      String
  createdAt DateTime @default(now())

  @@index([channel, createdAt])
  @@map("chat_messages")
}

enum Archetype {
  DUELIST
  SCHOLAR
  DIPLOMAT
}

model Character {
  id              String    @id @default(uuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id])
  name            String    @unique
  archetype       Archetype
  body            Int
  mind            Int
  presence        Int
  level           Int       @default(1)
  xp              Int       @default(0)
  hp              Int
  maxHp           Int
  actionPoints    Int       @default(10)
  maxActionPoints Int       @default(10)
  currentCityId   String
  gold            Int       @default(50)
  // Plain string, not an enum: professions are content-pack data (like
  // currentCityId/ItemInstance.itemId already are), not a fixed core set -
  // a new profession must never need a migration to exist.
  profession      String?
  professionLevel Int       @default(1)
  professionXp    Int       @default(0)
  items           ItemInstance[]
  craftingJobs    CraftingJob[]
  questProgress   QuestProgress[]
  // Derived, not a plain boolean: "currently a sworn duelist" depends on
  // comparing duelistOathRenounceRequestedAt (if set) against now - see
  // duel-eligibility.ts's isSwornDuelist(). Nothing sweeps a lapsed
  // renouncement on a timer; it's finalized lazily the next time this
  // character touches anything duel-related (M10 design discussion, same
  // idiom as CraftingJob's lazy resolution).
  duelistOathSwornAt             DateTime?
  duelistOathRenounceRequestedAt DateTime?
  duelsAsAttacker Duel[] @relation("DuelsAsAttacker")
  duelsAsDefender Duel[] @relation("DuelsAsDefender")
  dungeonRuns     DungeonRun[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("characters")
}

model ItemInstance {
  id          String   @id @default(uuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id])
  itemId      String
  equipped    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([characterId])
  @@index([characterId, equipped])
  @@map("item_instances")
}

model Guild {
  id        String        @id @default(uuid())
  name      String        @unique
  tag       String        @unique
  createdAt DateTime      @default(now())
  members   GuildMember[]
  invites   GuildInvite[]

  @@map("guilds")
}

enum GuildRole {
  LEADER
  OFFICER
  MEMBER
}

model GuildMember {
  id       String    @id @default(uuid())
  guildId  String
  guild    Guild     @relation(fields: [guildId], references: [id])
  userId   String    @unique
  user     User      @relation(fields: [userId], references: [id])
  role     GuildRole @default(MEMBER)
  joinedAt DateTime  @default(now())

  @@index([guildId])
  @@map("guild_members")
}

enum GuildInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model GuildInvite {
  id            String            @id @default(uuid())
  guildId       String
  guild         Guild             @relation(fields: [guildId], references: [id])
  invitedUserId String
  invitedUser   User              @relation("GuildInvitesReceived", fields: [invitedUserId], references: [id])
  invitedById   String
  invitedBy     User              @relation("GuildInvitesSent", fields: [invitedById], references: [id])
  status        GuildInviteStatus @default(PENDING)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([guildId, invitedUserId])
  @@index([invitedUserId, status])
  @@map("guild_invites")
}

model PrivateMessage {
  id          String    @id @default(uuid())
  senderId    String
  sender      User      @relation("PrivateMessagesSent", fields: [senderId], references: [id])
  recipientId String
  recipient   User      @relation("PrivateMessagesReceived", fields: [recipientId], references: [id])
  body        String
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([recipientId, createdAt])
  @@index([senderId, recipientId, createdAt])
  @@map("private_messages")
}

enum TradeOfferStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

// Deliberately one-directional (architecture.md's "trading is a social
// system wearing an economic costume" reading, game-design.md §6): the
// proposer's items/gold move to the target, the target only ever pays
// gold in return. A full item-for-item swap is just two of these,
// negotiated over chat/PM (already built in M5) - this avoids a proposer
// ever needing to reference the target's own item instance ids, which a
// bilateral "both sides add items to the same offer" model would require.
model TradeOffer {
  id                     String           @id @default(uuid())
  fromUserId             String
  fromUser               User             @relation("TradeOffersSent", fields: [fromUserId], references: [id])
  toUserId               String
  toUser                 User             @relation("TradeOffersReceived", fields: [toUserId], references: [id])
  offeredItemInstanceIds String[]
  offeredGold            Int              @default(0)
  requestedGold          Int              @default(0)
  status                 TradeOfferStatus @default(PENDING)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  @@index([toUserId, status])
  @@index([fromUserId, status])
  @@map("trade_offers")
}

// Append-only record of economy-critical actions (architecture.md §4.7/
// build-plan-v1.md M7: "audit log"). Written synchronously inside the
// same transaction as the action it records, not via the event bus -
// the whole point is that it survives even if nothing ever listens for
// the corresponding domain event.
model AuditLogEntry {
  id        String   @id @default(uuid())
  action    String
  actorId   String
  actor     User     @relation(fields: [actorId], references: [id])
  detail    Json
  createdAt DateTime @default(now())

  @@index([actorId, createdAt])
  @@map("audit_log")
}

enum CraftingJobStatus {
  IN_PROGRESS
  COMPLETED
}

// M8 (build-plan-v1.md, ADR-0001-adjacent design discussion): materials
// are consumed atomically when the job starts, not when it resolves -
// the character has committed to the craft, the output just isn't ready
// yet ("leave something in motion", vision.md §5). Resolution is lazy:
// nothing polls this table, a job whose completesAt has passed is
// resolved the next time any crafting endpoint is hit for that character
// (no background worker, per build-plan-v1.md §2/§4).
//
// Deliberately NOT modeled here, to keep future extension a pure logic
// change rather than a schema one: quantity (>1 is a trivially additive
// column later), quality/failure outcomes (the IN_PROGRESS -> COMPLETED
// resolution step is exactly where that logic would go), and queuing
// (whether a character may have more than one IN_PROGRESS job at a time
// is an application-level check in CraftingService, not a DB constraint -
// loosening it later doesn't touch this table).
model CraftingJob {
  id          String            @id @default(uuid())
  characterId String
  character   Character         @relation(fields: [characterId], references: [id])
  recipeId    String
  status      CraftingJobStatus @default(IN_PROGRESS)
  startedAt   DateTime          @default(now())
  completesAt DateTime
  resolvedAt  DateTime?

  @@index([characterId, status])
  @@map("crafting_jobs")
}

enum QuestStatus {
  IN_PROGRESS
  COMPLETED
}

// Quest and objective *definitions* are content-pack data (ContentService),
// same split as recipes/CraftingJob - this table holds only per-character
// *progress*. objectiveProgress is a parallel array to the content-defined
// objectives array (index 0 tracks objectives[0], etc.) rather than its own
// table, since objectives aren't independently addressable rows outside
// their quest (M9 design discussion; build-plan-v1.md §4.4: apply the
// cross-module transaction pattern directly, don't build a framework for
// it). No repeat/cooldown fields: repeatable quests are explicitly not a
// core platform feature (M9 design discussion) - a quest is completed at
// most once per character, enforced by the unique constraint below.
model QuestProgress {
  id                String      @id @default(uuid())
  characterId       String
  character         Character   @relation(fields: [characterId], references: [id])
  questId           String
  status            QuestStatus @default(IN_PROGRESS)
  objectiveProgress Int[]
  acceptedAt        DateTime    @default(now())
  completedAt       DateTime?

  @@unique([characterId, questId])
  @@index([characterId, status])
  @@map("quest_progress")
}

// M10 design discussion: PvP is opt-in only (the "duelist's oath" on
// Character above) and location-independent (no persisted "current
// region" state exists to gate on - see duel-eligibility.ts/duel.service.ts
// for why). This table holds only the *record* of each resolved duel;
// the pairwise repeat-attack cooldown is derived entirely from querying
// it (most recent duel between a given pair), not from a separate stored
// field.
model Duel {
  id                   String    @id @default(uuid())
  attackerCharacterId  String
  attackerCharacter    Character @relation("DuelsAsAttacker", fields: [attackerCharacterId], references: [id])
  defenderCharacterId  String
  defenderCharacter    Character @relation("DuelsAsDefender", fields: [defenderCharacterId], references: [id])
  // Always equal to attackerCharacterId, defenderCharacterId, or null for
  // a draw - not its own relation, since it never references a third
  // character.
  winnerCharacterId    String?
  attackerHpAfter      Int
  defenderHpAfter      Int
  goldTransferred      Int       @default(0)
  createdAt            DateTime  @default(now())

  @@index([attackerCharacterId, createdAt])
  @@index([defenderCharacterId, createdAt])
  @@map("duels")
}

enum DungeonRunStatus {
  IN_PROGRESS
  CLEARED
  RETREATED
}

// Presence-shaped in-progress state (M11 design discussion), not a
// commitment like QuestProgress or CraftingJob: nothing ever advances this
// row on its own - no cron, no timer, no background process. It changes
// only in direct response to an explicit player action (advance/retreat).
// It persists because the server is authoritative over where a character
// currently stands mid-expedition and has to remember that between
// requests - not because resuming an expedition days later is a feature
// worth designing for. retreat() is always callable regardless of how
// long a run has sat IN_PROGRESS, specifically so an abandoned expedition
// never becomes a permanent lock against entering anywhere else. No
// FAILED status: combat can't actually end a character (see
// combat-resolver.ts's HP-clamped-at-1 behavior), so a dungeon run only
// ever ends by reaching the last beat (CLEARED) or by the player choosing
// to stop (RETREATED).
model DungeonRun {
  id           String           @id @default(uuid())
  characterId  String
  character    Character        @relation(fields: [characterId], references: [id])
  dungeonId    String
  status       DungeonRunStatus @default(IN_PROGRESS)
  currentBeat  Int              @default(0)
  startedAt    DateTime         @default(now())
  resolvedAt   DateTime?

  @@index([characterId, status])
  @@map("dungeon_runs")
}
