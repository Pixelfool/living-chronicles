generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String          @id @default(uuid())
  email                  String          @unique
  username               String          @unique
  passwordHash           String
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  character              Character?
  friendRequestsSent     FriendRequest[] @relation("FriendRequestsSent")
  friendRequestsReceived FriendRequest[] @relation("FriendRequestsReceived")
  mutesMade              Mute[]          @relation("MutesMade")
  mutesReceived          Mute[]          @relation("MutesReceived")
  chatMessages           ChatMessage[]

  @@map("users")
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model FriendRequest {
  id          String              @id @default(uuid())
  requesterId String
  requester   User                @relation("FriendRequestsSent", fields: [requesterId], references: [id])
  addresseeId String
  addressee   User                @relation("FriendRequestsReceived", fields: [addresseeId], references: [id])
  status      FriendRequestStatus @default(PENDING)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@map("friend_requests")
}

model Mute {
  id        String   @id @default(uuid())
  muterId   String
  muter     User     @relation("MutesMade", fields: [muterId], references: [id])
  mutedId   String
  muted     User     @relation("MutesReceived", fields: [mutedId], references: [id])
  createdAt DateTime @default(now())

  @@unique([muterId, mutedId])
  @@map("mutes")
}

model ChatMessage {
  id        String   @id @default(uuid())
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  channel   String   @default("global")
  body      String
  createdAt DateTime @default(now())

  @@index([channel, createdAt])
  @@map("chat_messages")
}

enum Archetype {
  DUELIST
  SCHOLAR
  DIPLOMAT
}

model Character {
  id              String    @id @default(uuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id])
  name            String    @unique
  archetype       Archetype
  body            Int
  mind            Int
  presence        Int
  level           Int       @default(1)
  xp              Int       @default(0)
  hp              Int
  maxHp           Int
  actionPoints    Int       @default(10)
  maxActionPoints Int       @default(10)
  currentCityId   String
  items           ItemInstance[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("characters")
}

model ItemInstance {
  id          String   @id @default(uuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id])
  itemId      String
  equipped    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([characterId])
  @@index([characterId, equipped])
  @@map("item_instances")
}
