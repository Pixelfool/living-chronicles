# Postgres
POSTGRES_USER=living_chronicles
POSTGRES_PASSWORD=change_me
POSTGRES_DB=living_chronicles

# App
PORT=3000
NODE_ENV=development
SESSION_SECRET=change_me

# For host-side tooling (Prisma CLI, `npm run start:dev` against the
# Dockerized Postgres/Redis). Inside docker-compose, the app container
# gets its own service-DNS-based values instead (see docker-compose.yml).
DATABASE_URL=postgres://living_chronicles:change_me@localhost:5432/living_chronicles
REDIS_URL=redis://localhost:6379
